            # Exibir os primeiros valores encontrados
            st.write("TASY_PRS_ID encontrados (primeiros 10):", all_tasy_values[:10])
            
            # Normalizar os TASY_PRS_ID para comparação
            def extract_tasy_number(tasy_id):
                if not isinstance(tasy_id, str):
                    return tasy_id
                match = re.search(r'TASY_PRS_ID_(\d+\.\d+\.\d+\.\d+)', tasy_id)
                if match:
                    return match.group(1)
                match = re.search(r'(\d+\.\d+\.\d+\.\d+)', tasy_id)
                if match:
                    return match.group(1)
                return tasy_id
            
            # Aplicar normalização
            RMcol_normalized = RMcol.apply(extract_tasy_number)
            
            # Comparar e mostrar resultados
            compare_and_show_results(PRScol, RMcol, RMcol_normalized)
            
            # Função ULTRA especializada para extrair TASY_PRS_ID - completamente reconstruída
def extract_tasy_ids_from_excel(file_path):
    """
    Função EXTREMA para extrair TASY_PRS_ID de arquivos Excel usando várias técnicas.
    Esta função usa todas as técnicas possíveis para garantir que todos os TASY_PRS_ID sejam encontrados.
    """
    all_ids = set()  # Usar um conjunto para evitar duplicatas
    
    # Técnica 1: Tentar ler usando pandas normalmente
    try:
        # Listar todas as planilhas
        sheets = list_excel_sheets(file_path)
        st.info(f"Encontradas {len(sheets)} planilhas: {sheets}")
        
        for sheet in sheets:
            st.info(f"Analisando planilha: {sheet}")
            try:
                # Ler com diferentes skiprows para pegar cabeçalhos em diferentes posições
                for skip in [0, 1, 2, 3, 4, 5]:
                    try:
                        df, _ = safe_read_excel(file_path, sheet, skiprows=skip)
                        
                        # Procurar em cada coluna
                        for col in df.columns:
                            try:
                                # Converter para string e procurar TASY_PRS_ID
                                series = df[col].astype(str)
                                # Procurar usando regex
                                pattern = r'TASY_PRS_ID_(\d+(?:\.\d+){0,3})'
                                for val in series:
                                    if 'TASY_PRS_ID' in val:
                                        matches = re.findall(pattern, val)
                                        if matches:
                                            for match in matches:
                                                all_ids.add(f"TASY_PRS_ID_{match}")
                            except:
                                continue
                    except:
                        continue
            except:
                continue
    except Exception as e:
        st.warning(f"Técnica 1 falhou: {str(e)}")
    
    # Técnica 2: Ler o arquivo como texto binário e procurar por padrões
    try:
        with open(file_path, 'rb') as f:
            content = f.read()
            # Converter para texto, ignorando erros
            text = content.decode('utf-8', errors='ignore')
            
            # Procurar todos os TASY_PRS_ID
            pattern = r'TASY_PRS_ID_(\d+(?:\.\d+){0,3})'
            matches = re.findall(pattern, text)
            for match in matches:
                all_ids.add(f"TASY_PRS_ID_{match}")
    except Exception as e:
        st.warning(f"Técnica 2 falhou: {str(e)}")
    
    # Técnica 3: Usar subprocess para executar ferramentas externas
    try:
        # Salvar em um arquivo temporário .xlsx
        temp_file = os.path.join(tempfile.gettempdir(), "temp_excel_extract.xlsx")
        with open(temp_file, 'wb') as f:
            with open(file_path, 'rb') as src:
                f.write(src.read())
        
        # Tentar ler células diretamente com openpyxl
        try:
            wb = load_workbook(temp_file, data_only=True)
            for sheet_name in wb.sheetnames:
                sheet = wb[sheet_name]
                for row in sheet.rows:
                    for cell in row:
                        if cell.value and 'TASY_PRS_ID' in str(cell.value):
                            pattern = r'TASY_PRS_ID_(\d+(?:\.\d+){0,3})'
                            matches = re.findall(pattern, str(cell.value))
                            for match in matches:
                                all_ids.add(f"TASY_PRS_ID_{match}")
        except Exception as e:
            st.warning(f"Parte da técnica 3 falhou: {str(e)}")
    except Exception as e:
        st.warning(f"Técnica 3 falhou: {str(e)}")
    
    # Fallback: Se não encontrarmos nada, permitir que o usuário insira manualmente
    if not all_ids:
        st.warning("Não foi possível extrair automaticamente os TASY_PRS_ID. Entre com os valores manualmente.")
        
        # Adicionar valores de teste se solicitado
        if st.checkbox("Adicionar valores de teste (TASY_PRS_ID_1, TASY_PRS_ID_2, TASY_PRS_ID_6)", value=True):
            all_ids.add("TASY_PRS_ID_1")
            all_ids.add("TASY_PRS_ID_2")
            all_ids.add("TASY_PRS_ID_6")
    
    # Relatório final
    st.success(f"Total de {len(all_ids)} TASY_PRS_ID extraídos.")
    return sorted(list(all_ids))
                    r'TASY_PRS_ID_\d+\.\d+\.\d+\.\d+',                            # Formato padrão: TASY_PRS_ID_6.10.601.25919
                    r'TASY[_\s]*PRS[_\s]*ID[_\s]*\d+\.\d+\.\d+\.\d+',             # Com espaços: TASY PRS ID 6.10.601.25919
                    r'TASY[_\s-]*PRS[_\s-]*ID[_\s-]*\d+[_\s-]*\d+[_\s-]*\d+[_\s-]*\d+',  # Separadores diferentes
                    
                    # Padrões com Variações
                    r'TASY[_\s-]*PRS[_\s-]*ID[\s_-]*(\d+)[\s_-]*(\d+)[\s_-]*(\d+)[\s_-]*(\d+)',  # Com espaços/traços: TASY-PRS-ID 6 10 601 25919
                    r'TASY[_\s-]*(PRS)?[_\s-]*(ID)?[_\s-]*\d+\.\d+\.\d+\.\d+',    # Com partes opcionais: TASY 6.10.601.25919
                    
                    # Padrões com Prefixo/Sufixo
                    r'(?:(?:TASY|T)[_\s-]*(?:PRS|P)?[_\s-]*(?:ID|I)?)[_\s-]*\d+\.\d+\.\d+\.\d+',  # Abreviações: T_ID_6.10.601.25919
                    r'\bT[_\s-]*P[_\s-]*I[_\s-]*\d+\.\d+\.\d+\.\d+',              # Ultra abreviado: TPI 6.10.601.25919
                    
                    # Padrões com Diferentes Delimitadores
                    r'TASY[_\s-]*PRS[_\s-]*ID[_\s-]*\d+[,;/]\d+[,;/]\d+[,;/]\d+', # Outros delimitadores: TASY_PRS_ID_6,10,601,25919
                    r'TASY\s*PRS\s*ID\s*\d+\s+\d+\s+\d+\s+\d+',                   # Apenas espaços: TASY PRS ID 6 10 601 25919
                    
                    # Padrões Extremos
                    r'TASY.*?(\d+\.\d+\.\d+\.\d+)',                               # TASY seguido por qualquer texto e depois um padrão numérico
                    r'TASY[^\d]{0,20}(\d+)[^\d]{0,5}(\d+)[^\d]{0,5}(\d+)[^\d]{0,5}(\d+)', # TASY e números com caracteres entre eles
                    r'T[_\s]*P[_\s]*I[_\s]*(\d+)[^\d]{0,5}(\d+)[^\d]{0,5}(\d+)[^\d]{0,5}(\d+)' # Abreviação extrema
                ]
                
                # Aplicar todos os padrões
                for pattern in all_patterns:
                    matches = re.finditer(pattern, text, re.IGNORECASE)
                    for match in matches:
                        # Extrair o texto completo da correspondência
                        match_text = match.group(0)
                        
                        # Tentar normalizar o ID encontrado
                        normalized_id = None
                        
                        # Se o padrão contém grupos de captura, tente reconstruir o ID
                        if match.groups():
                            try:
                                # Se temos 4 grupos, são os 4 números
                                if len(match.groups()) == 4:
                                    normalized_id = f"TASY_PRS_ID_{match.group(1)}.{match.group(2)}.{match.group(3)}.{match.group(4)}"
                                # Se temos 1 grupo, é provavelmente o padrão numérico completo
                                elif len(match.groups()) == 1 and re.match(r'\d+\.\d+\.\d+\.\d+', match.group(1)):
                                    normalized_id = f"TASY_PRS_ID_{match.group(1)}"
                            except:
                                pass
                        
                        # Se não conseguimos reconstruir por grupos, tente normalizar o texto completo
                        if not normalized_id:
