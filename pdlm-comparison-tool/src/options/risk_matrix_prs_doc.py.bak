                            if len(all_tasy_values) < 5:
                                st.success(f"✓ ID extraído: {normalized_id} (de: {match_text})")
                
                # PHASE 2: EXTRAÇÃO CONTEXTUAL - Analisar o contexto ao redor das menções a TASY
                if 'TASY' in text.upper():
                    # Encontrar todas as menções a TASY_PRS_ID e variações
                    tasy_positions = []
                    tasy_patterns = [
                        r'TASY[_\s-]*PRS[_\s-]*ID', r'TASY[\s-]*ID', r'TASY_ID', 
                        r'\bTASY\b', r'\bTPRS\b', r'\bTPI\b'
                    ]
                    
                    for pattern in tasy_patterns:
                        for match in re.finditer(pattern, text, re.IGNORECASE):
                            tasy_positions.append(match.start())
                    
                    # Ordenar posições e eliminar duplicatas
                    tasy_positions = sorted(set(tasy_positions))
                    
                    # Para cada posição onde TASY é mencionado
                    for pos in tasy_positions:
                        # Pegar um fragmento grande do texto após a menção a TASY (até 300 caracteres)
                        fragment = text[pos:pos+300]
                        
                        # Procurar por padrões numéricos no formato X.X.X.X próximos
                        numeric_patterns = re.finditer(r'(\d+\.\d+\.\d+\.\d+)', fragment)
                        
                        for num_match in numeric_patterns:
                            # Se o número está próximo à menção a TASY (menos de 50 caracteres), considerar uma correspondência
                            if num_match.start() < 50:
                                normalized_id = f"TASY_PRS_ID_{num_match.group(1)}"
                                final_ids.append(normalized_id)
                                # Debug
                                if len(final_ids) <= 5:
                                    st.info(f"✓ ID por proximidade: {normalized_id} (distância: {num_match.start()} caracteres)")
                
                # PHASE 3: RECONSTRUÇÃO DE FRAGMENTOS - Para textos onde os IDs estão espalhados ou fragmentados
                if not final_ids and 'TASY' in text.upper():
                    # Procurar por menções a "TASY" seguidas por números
                    tasy_with_numbers = re.finditer(r'TASY[_\s-]*(?:PRS)?[_\s-]*(?:ID)?[_\s-]*(\d+)', text, re.IGNORECASE)
                    
                    for match in tasy_with_numbers:
                        simple_id = match.group(1)
                        # Procurar por um padrão numérico completo próximo que comece com este número
                        start_pos = match.start()
                        end_pos = min(start_pos + 500, len(text))
                        search_fragment = text[start_pos:end_pos]
                        
                        # Procurar pelo padrão numérico completo
                        for pattern_match in re.finditer(r'(\d+\.\d+\.\d+\.\d+)', search_fragment):
                            pattern = pattern_match.group(1)
                            if pattern.startswith(f"{simple_id}."):
                                normalized_id = f"TASY_PRS_ID_{pattern}"
                                final_ids.append(normalized_id)
                                if len(final_ids) <= 5:
                                    st.success(f"✓ ID reconstruído: {normalized_id}")
                                break
                
                # PHASE 4: MINERAÇÃO AGRESSIVA - Tentar extrair informações de células problemáticas
                if not final_ids and len(text) < 1000 and ('TASY' in text.upper() or 'PRS' in text.upper()):
                    # Extrair todos os números no formato X.X.X.X
                    all_patterns = re.findall(r'(\d+\.\d+\.\d+\.\d+)', text)
                    
                    # Se encontrou padrões numéricos e há menção a TASY/PRS
                    if all_patterns and ('TASY' in text.upper() or 'PRS' in text.upper()):
