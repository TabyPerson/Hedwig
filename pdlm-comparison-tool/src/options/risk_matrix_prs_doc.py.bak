                    number_fragments = re.findall(r'\b(\d+)\b', text)
                    
                    if len(number_fragments) >= 4:
                        # Tentar reconstruir o padrão usando os primeiros 4 números encontrados
                        try:
                            reconstructed = f"{number_fragments[0]}.{number_fragments[1]}.{number_fragments[2]}.{number_fragments[3]}"
                            normalized_id = f"TASY_PRS_ID_{reconstructed}"
                            final_ids.append(normalized_id)
